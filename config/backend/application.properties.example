# DentalCare Pro — Backend Configuration
# 1. Copiare come: config/backend/application.properties
# 2. Completare i valori reali (NON committare — contiene credenziali)
# Se questo file non esiste, Spring usa i default del classpath (LAN dev).

# ---- Database (PostgreSQL) ----
spring.datasource.url=jdbc:postgresql://192.168.0.173:5432/DentalCare_Prod
spring.datasource.username=postgres
spring.datasource.password=CHANGE_ME
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=2
spring.datasource.hikari.connection-timeout=20000

# ---- JPA ----
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=false

# ---- Flyway (gestito manualmente) ----
spring.flyway.enabled=false

# ---- Jackson ----
spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.default-property-inclusion=non_null

# ---- JWT (usare secret reale, min 32 chars) ----
# Genera con: openssl rand -base64 48
app.jwt.secret=CHANGE_ME_REPLACE_WITH_REAL_SECRET_MIN_32_CHARS
app.jwt.expiration-ms=86400000

# ---- Demo mode (disabilitare in produzione) ----
app.demo.enabled=false

# ---- Tenant provisioning ----
tenant.tablespace.base-path=

# ---- Mail (SMTP) ----
spring.mail.host=192.168.0.68
spring.mail.port=9143
spring.mail.username=
spring.mail.password=
spring.mail.properties.mail.smtp.auth=false
spring.mail.properties.mail.smtp.starttls.enable=false
spring.mail.properties.mail.smtp.ssl.enable=false
app.mail.from=noreply@dentalcare.it
# true = invia email reali via SMTP; false = scrive file MHTML in ./fakesmtp/
app.mail.send-real-emails=true

# ---- Server ----
server.port=8080

# ---- Logging ----
logging.level.root=INFO
logging.level.com.dentalcare=INFO
logging.level.org.springframework.jdbc.core=WARN

# ---- Errori (disabilitare in produzione) ----
server.error.include-message=never
server.error.include-binding-errors=never
